<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rabbiter.ol.dao.SubjectDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.rabbiter.ol.entity.SubjectEntity" id="subjectMap">
        <result property="id" column="id"/>
        <result property="courseName" column="course_name"/>
        <result property="description" column="description"/>
        <result property="creatorId" column="creator_id"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="baseQuery">
        c.id,
        c.course_name AS courseName,
        c.description,
        c.creator_id AS creatorId,
        c.cover_url AS coverUrl,
        c.status,
        c.create_time AS createTime,
        c.update_time AS updateTime
    </sql>

    <select id="queryCount" resultType="java.lang.Integer">
        SELECT
        COUNT(*) AS total
        FROM
        `course` c
        LEFT JOIN `class` cl ON c.id = cl.course_id
        LEFT JOIN user_class uc ON cl.id = uc.class_id
        <where>
            <if test="classId != null">
                AND uc.class_id = #{classId}
            </if>
        </where>
    </select>

    <select id="queryData" resultType="java.util.HashMap">
        SELECT
        *
        FROM
        `course` c
        LEFT JOIN `class` cl ON c.id = cl.course_id
        LEFT JOIN user_class uc ON cl.id = uc.class_id
        <where>
            <if test="classId != null">
                AND uc.class_id = #{classId}
            </if>
        </where>
        ORDER BY c.id DESC
        LIMIT #{page},#{pageSize}
    </select>


    <select id="queryList" resultType="java.util.HashMap">
        SELECT
        <include refid="baseQuery"></include>
        FROM
        `course` c
        LEFT JOIN `class` cl ON c.id = cl.course_id
        LEFT JOIN user_class uc ON cl.id = uc.class_id
        <where>
            <if test="classId != null">
                AND uc.class_id = #{classId}
            </if>
        </where>
    </select>

    <select id="findPageCount" resultType="java.lang.Integer">
        SELECT
        COUNT(*) AS total
        FROM
        `course` c
    </select>

    <select id="findPageData" resultType="java.util.HashMap">
        SELECT
        <include refid="baseQuery"></include>
        FROM
        `course` c
        ORDER BY c.id DESC
        LIMIT #{page},#{pageSize}
    </select>


</mapper>