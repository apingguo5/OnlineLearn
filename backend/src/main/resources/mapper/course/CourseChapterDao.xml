<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rabbiter.ol.dao.course.CourseChapterDao">

    <resultMap type="com.rabbiter.ol.entity.course.CourseChapterEntity" id="chapterMap">
        <result property="id" column="id"/>
        <result property="classId" column="class_id"/>
        <result property="chapterName" column="chapter_name"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="queryListByClassId" resultType="java.util.HashMap">
        SELECT
            cc.id,
            cc.chapter_name AS chapterName,
            cc.sort_order AS sortOrder,
            cc.create_time AS createTime,
            IFNULL((SELECT COUNT(*) FROM chapter_resource_ref crf WHERE crf.chapter_id = cc.id), 0) AS resourceCount
        FROM course_chapter cc
        WHERE cc.class_id = #{classId}
        ORDER BY cc.sort_order ASC, cc.id ASC
    </select>

</mapper>