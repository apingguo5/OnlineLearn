<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rabbiter.ol.dao.GradeWeightDao">
    <resultMap id="baseMap" type="com.rabbiter.ol.entity.GradeWeightEntity">
        <id column="id" property="id" />
        <result column="class_id" property="classId" />
        <result column="weight_name" property="weightName" />
        <result column="weight_percent" property="weightPercent" />
        <result column="sort_order" property="sortOrder" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="baseColumns">
        id, class_id, weight_name, weight_percent, sort_order, create_time, update_time
    </sql>

</mapper>