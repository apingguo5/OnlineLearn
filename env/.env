# =============================================
# OnlineLearn 环境变量配置（单一数据源）
# =============================================
# 修改此文件后，CMD 和 PowerShell 都会生效
# 如需本地覆盖，请复制为 .env.local 并修改
# =============================================

# ----- JDK 配置 -----
JAVA_HOME=D:\Environment\jdk1.8.0_202

# ----- Maven 配置 -----
MAVEN_HOME=D:\Environment\maven\apache-maven-3.9.14

# ----- Node.js 配置 -----
NODE_HOME=C:\Program Files\nodejs

# ----- MySQL 配置 -----
MYSQL_HOST=192.168.1.38
MYSQL_PORT=3306
MYSQL_DATABASE=online_learn
MYSQL_USER=newuser
MYSQL_PASSWORD=yourpassword

# ----- 项目端口配置 -----
BACKEND_PORT=9251
FRONTEND_PORT=9252

# ----- 构建/启动选项 -----
# 构建后端时是否跳过测试 (true/false)
SKIP_TESTS=true
# 前端 npm install 参数（Node 17+ 需要 --legacy-peer-deps）
NPM_INSTALL_ARGS=--legacy-peer-deps